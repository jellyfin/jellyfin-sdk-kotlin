# Required
JELLYFIN_SERVER=

# Choose one auth method
# JELLYFIN_API_KEY=YOUR_API_KEY
JELLYFIN_USERNAME=
JELLYFIN_PASSWORD=

# Secondary user for SyncPlay multi-user tests
# JELLYFIN_SECOND_API_KEY=YOUR_SECOND_API_KEY
JELLYFIN_SECOND_USERNAME=
JELLYFIN_SECOND_PASSWORD=

# Optional client/device metadata
JELLYFIN_CLIENT_NAME=Jellyfin SDK Test
JELLYFIN_CLIENT_VERSION=0.0.0
JELLYFIN_DEVICE_NAME=Test Device
# JELLYFIN_DEVICE_ID=your-device-id

# WebSocket test settings
JELLYFIN_WEBSOCKET=true
JELLYFIN_WS_DURATION_MS=10000

# SyncPlay test settings
JELLYFIN_SYNCPLAY=true
JELLYFIN_SYNCPLAY_GROUP_NAME=SDK Test Group
# Comma-separated Jellyfin item UUIDs for queue/play tests
JELLYFIN_SYNCPLAY_ITEM_IDS=
# Playlist item UUID for ready/next/previous/move/remove tests
JELLYFIN_SYNCPLAY_PLAYLIST_ITEM_ID=

# Item listing (to discover IDs)
JELLYFIN_LIST_ITEMS=false
JELLYFIN_ITEMS_LIMIT=20
# Optional parent folder id to scope items
JELLYFIN_ITEMS_PARENT_ID=
# Optional include types, comma-separated (e.g. Movie,Series,Episode)
JELLYFIN_ITEMS_INCLUDE_TYPES=
